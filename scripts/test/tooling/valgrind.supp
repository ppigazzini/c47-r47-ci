# Curated Valgrind suppressions for the c43 testSuite.
# These silence known third-party noise (GTK/GLib/fontconfig type caches, the
# one-time GMP allocation) so a real malloc-level error or leak in c47 code
# stands out. Keep this list tight: suppress libraries, never c47 frames.

{
   glib-type-registration-one-time-init
   Memcheck:Leak
   ...
   obj:*/libglib-2.0.so*
}
{
   gobject-type-system-one-time-init
   Memcheck:Leak
   ...
   obj:*/libgobject-2.0.so*
}
{
   gtk-init-static-caches
   Memcheck:Leak
   ...
   obj:*/libgtk-3.so*
}
{
   gdk-init-static-caches
   Memcheck:Leak
   ...
   obj:*/libgdk-3.so*
}
{
   fontconfig-pattern-cache
   Memcheck:Leak
   ...
   obj:*/libfontconfig.so*
}
{
   pango-static-init
   Memcheck:Leak
   ...
   obj:*/libpango*-1.0.so*
}
{
   gmp-realloc-scratch
   Memcheck:Leak
   ...
   obj:*/libgmp.so*
}

# decNumber decFloatFMA reads its BCD accumulator four digits at a time with
# UBTOUI (a read-4-bytes macro) when stripping leading zeros. The accumulator
# (dep/decNumberICU/decBasic.c:2002, "uByte acc[FMALEN]") is rounded up to a
# uInt boundary with ROUNDUP4, so the final read can touch padding past the
# significant digits - which decNumber documents as safe ("tests are safe
# because acc and coe are rounded up to uInts", decBasic.c:2082). clang's
# codegen makes Memcheck flag that masked over-read as a conditional on
# uninitialised data; gcc does not, confirming it is a decNumber-internal
# artefact, not a c47 defect (c47 passes a fully-defined value in - here a
# date register from decodeLiteral). decNumber is compiled into the binary, so
# this matches by function, not obj:. Scope it to the decNumber caller frame
# (decDivide -> decQuadFMA) so a value c47 itself fails to initialise and feeds
# straight into a decQuad op is still reported.
{
   decnumber-decquad-fma-bcd-uint-overread
   Memcheck:Cond
   fun:decQuadFMA
   fun:decDivide
}
