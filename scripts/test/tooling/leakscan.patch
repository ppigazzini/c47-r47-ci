+        if(nm[0] == 0) {
+          nm = indexOfItems[item].itemSoftmenuName;
+        }
+        fflush(stdout);
+        fflush(stderr);
+        pid_t pid = fork();
+        if(pid == 0) {
+          alarm(4); // a hanging item self-terminates and is reported as a crash
+          leakscanSetupStack(type);
+          lastErrorCode = 0;
+          reallyRunFunction(item, indexOfItems[item].param);
+          fnClAll(CONFIRMED);
+          int32_t net = ((int32_t)baseline - (int32_t)getFreeRamMemory()) - refDelta;
+          long gmpNet = (long)gmpMemInBytes - (long)gmpBaseline;
+          if(net > 0 || gmpNet > 0) {
+            printf("LEAK  type=%-7s item=%4d %-16s pool=%d gmp=%ld\n", typeName[type], item, nm, net > 0 ? net : 0, gmpNet > 0 ? gmpNet : 0L);
+          }
+          fflush(stdout);
+          _exit((net > 0 || gmpNet > 0) ? 1 : 0);
+        }
+        else if(pid > 0) {
+          int status = 0;
+          waitpid(pid, &status, 0);
+          if(WIFSIGNALED(status)) {
+            printf("CRASH type=%-7s item=%4d %-16s signal=%d\n", typeName[type], item, nm, WTERMSIG(status));
+            totalCrash++;
+          }
+          else if(WIFEXITED(status) && WEXITSTATUS(status) == 1) {
+            totalLeak++;
+          }
+        }
+      }
+    }
+    printf("LEAKSCAN done: %d leaking (item,type) pairs, %d crashing (item,type) pairs\n", totalLeak, totalCrash);
+    return 0;
+  }
