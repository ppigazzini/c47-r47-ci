+// Fill the stack registers X, Y, Z, T, L with a representative value of one
+// data type so the leak scanner can drive type-specific allocation paths.
+static void leakscanSetupStack(int type) {
+  const calcRegister_t regs[5] = {REGISTER_X, REGISTER_Y, REGISTER_Z, REGISTER_T, REGISTER_L};
+  for(int k = 0; k < 5; k++) {
+    calcRegister_t r = regs[k];
+    if(type == 0) {        // real
+      real34_t t;
+      int32ToReal34(2, &t);
+      reallocateRegister(r, dtReal34, 0, amNone);
+      real34Copy(&t, REGISTER_REAL34_DATA(r));
+    }
+    else if(type == 1) {   // string
+      const char *s = "leakScanString";
+      reallocateRegister(r, dtString, TO_BLOCKS(stringByteLength((char *)s) + 1), amNone);
+      strcpy(REGISTER_STRING_DATA(r), s);
+    }
+    else if(type == 2) {   // long integer
+      longInteger_t li;
+      longIntegerInit(li);
+      uInt32ToLongInteger(123456789u, li);
+      convertLongIntegerToLongIntegerRegister(li, r);
+      longIntegerFree(li);
+    }
+    else if(type == 3) {   // complex
+      real34_t t;
+      int32ToReal34(2, &t);
+      reallocateRegister(r, dtComplex34, 0, amNone);
+      real34Copy(&t, REGISTER_REAL34_DATA(r));
+      real34Copy(&t, REGISTER_IMAG34_DATA(r));
+    }
+  }
+}
