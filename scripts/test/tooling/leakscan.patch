+  // Memory-leak scanner for the calculator's own RAM pool (not malloc/ASan).
+  // Runs every item once on a generic real stack, clears all state, and reports
+  // any item whose freeing did not return the C47 RAM pool to baseline. Each
+  // item runs in a forked child so a crash or hang (alarm) is isolated and
+  // reported instead of aborting the scan.
+  if(argc >= 2 && strcmp(argv[1], "--leakscan") == 0) {
+    // setupStack + fnClAll has a fixed per-cycle footprint in the RAM pool
+    // (menu rebuild etc.). Measure it per stack type as a reference and
+    // subtract it so only a function's own excess pool leak is reported. Each
+    // item runs in a forked child so a crash or hang (alarm) is isolated and
+    // reported rather than aborting the scan.
+    const char *typeName[4] = {"real", "string", "longint", "complex"};
+    fnClAll(CONFIRMED);
+    uint32_t baseline = getFreeRamMemory();
+    size_t gmpBaseline = gmpMemInBytes;
+    printf("LEAKSCAN start: baseline=%u blocks, gmpBaseline=%zu bytes; items 1..%d; stack types real,string,longint,complex\n", baseline, gmpBaseline, LAST_ITEM);
+    fflush(stdout);
+
+    int totalLeak = 0, totalCrash = 0;
+    for(int type = 0; type < 4; type++) {
+      int32_t refDelta = 0;
+      {
+        pid_t pid = fork();
+        if(pid == 0) {
+          leakscanSetupStack(type);
+          fnClAll(CONFIRMED);
+          _exit((int)(((int32_t)baseline - (int32_t)getFreeRamMemory()) & 0xFF));
+        }
+        int st = 0;
+        waitpid(pid, &st, 0);
+        refDelta = WIFEXITED(st) ? WEXITSTATUS(st) : 0;
+      }
+      printf("--- stack type %s (reference overhead %d blocks) ---\n", typeName[type], refDelta);
+      fflush(stdout);
+
+      for(int item = 1; item <= LAST_ITEM; item++) {
