+// Free the calculator working state a test case can populate - statistical
+// sums, local registers, and all global registers - WITHOUT touching programs
+// (the test corpus relies on the preloaded test programs), menus, or flags and
+// modes (set by the per-file global IN line). Mirrors the relevant subset of
+// fnClAll. After this, a clean test case returns the pool/GMP to baseline; a
+// case that orphaned pool or GMP blocks does not.
+static void testMemClearWorkingState(void) {
+  fnClSigma(CONFIRMED);
+  if(savedStatisticalSumsPointer != NULL) {
+    freeC47Blocks(savedStatisticalSumsPointer, NUMBER_OF_STATISTICAL_SUMS * REAL_SIZE_IN_BLOCKS(75));
+    savedStatisticalSumsPointer = NULL;
+  }
+  allocateLocalRegisters(0);
+  for(calcRegister_t r = FIRST_GLOBAL_REGISTER; r <= LAST_GLOBAL_REGISTER; r++) {
+    clearRegister(r);
+  }
+}
+
+// Clear the working state and attribute any pool/GMP not returned to baseline to
+// the just-completed test case (identified by its IN line, still in
+// lastInParameters because this runs before the next IN overwrites it).
+static void testMemCheck(void) {
+  testMemClearWorkingState();
+  uint32_t freeNow = getFreeRamMemory();
+  int32_t poolGrow = (int32_t)testMemPrevFree - (int32_t)freeNow; // >0: this case kept pool blocks
+  long gmpGrow = (long)gmpMemInBytes - (long)testMemPrevGmp;      // >0: this case kept GMP
+  if(poolGrow > 0 || gmpGrow > 0) {
+    testMemLeakCases++;
+    printf("\nTESTMEM GROWTH file=%s pool=+%d gmp=+%ld\n  case: %s\n", fileName, (int)poolGrow, gmpGrow, lastInParameters);
+  }
+  // Ratchet: only growth beyond the new high-water is reported next time, so a
+  // persistent object (named variable, equation) is attributed to the one case
+  // that created it, not to every case after it.
+  testMemPrevFree = freeNow;
+  testMemPrevGmp = gmpMemInBytes;
+}
